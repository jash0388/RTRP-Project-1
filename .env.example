# ============================================================
# RoadSuraksha / SPHN — Environment Variables
# ============================================================
# Copy this file to ".env" in the project ROOT and fill in real values.
# NEVER commit the real .env file to GitHub (already in .gitignore).
# ============================================================

# ----- Server / Backend -----
NODE_ENV=development
PORT=3001

# JWT signing secret — generate your own with: openssl rand -hex 48
JWT_SECRET=replace_me_with_a_long_random_hex_string

# ----- Database (PostgreSQL) -----
# Use a Postgres URL — works with Supabase, Neon, Render, or local Postgres.
# On Replit this is auto-set; locally you must provide one.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ----- Firebase (server-side admin token verification) -----
# Project ID is enough for verifying client-issued ID tokens.
FIREBASE_PROJECT_ID=rtrp-a11b1

# ----- Supabase (public client values — already hardcoded in client/src/supabase.js) -----
# Listed here for reference; client uses them directly.
SUPABASE_URL=https://gyttwfymmowfrvgvvgda.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imd5dHR3ZnltbW93ZnJ2Z3Z2Z2RhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcwMzc2MTIsImV4cCI6MjA5MjYxMzYxMn0.lY5e1wt1j78OQrFha8dO-iP3O2ZupyW7XPPegC8zboQ

# ----- Supabase JWT secret (only needed if validating Supabase tokens server-side) -----
# Get this from your Supabase project settings > API > JWT secret
# SUPABASE_JWT_SECRET=

# ----- Google OAuth (optional — only if using Google Sign-In) -----
# GOOGLE_CLIENT_ID=

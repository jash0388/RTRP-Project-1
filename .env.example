# ============================================================
# RoadSuraksha / SPHN — Environment Variables
# ============================================================
# Copy this file to ".env" in the project ROOT and fill in real values.
# Never commit the real .env file to GitHub.
# ============================================================

# ----- Server / Backend -----
NODE_ENV=development
PORT=3001

# JWT signing secret (use a long random string — generate with: openssl rand -hex 48)
JWT_SECRET=replace_me_with_a_long_random_hex_string

# ----- Database (PostgreSQL) -----
# Either provide a full DATABASE_URL (recommended — works with Supabase, Neon, Render, local PG)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# OR (only if DATABASE_URL is not set) fall back to MySQL — leave blank if using Postgres
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=sphn_db

# ----- Firebase (server-side admin token verification) -----
# Project ID is enough for verifying client-issued ID tokens
FIREBASE_PROJECT_ID=rtrp-a11b1

# ----- Google OAuth (optional — only if using Google Sign-In) -----
# GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ----- Supabase (optional — only if using Supabase auth tokens server-side) -----
# SUPABASE_JWT_SECRET=your_supabase_jwt_secret
